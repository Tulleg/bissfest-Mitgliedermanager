# Environment Variables
# Kopiere diese Datei zu .env und passe die Werte an

# Node Environment
NODE_ENV=development

# Server Port
PORT=3500

# Trust Proxy (für Production hinter Reverse Proxy)
TRUST_PROXY=false

# Session Secret (wird Auto-generiert in data/.session-secret falls nicht gesetzt)
# SESSION_SECRET=dein-sehr-sicherer-zufälliger-string-hier

# Database Path (optional, Standard: ./data/app.db)
# DATABASE_PATH=./data/app.db
